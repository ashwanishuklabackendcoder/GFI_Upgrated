@page "/store/reports/item-stock-by-batch"
@page "/admin/reports/item-stock-by-batch"
@page "/store/itemstocklist"
@page "/admin/itemstocklist"
@using GFI_Upgrated.SharedDto.Store
@using GFI_Upgrated.SharedDto.Common
@using GFI_Upgrated.UI.Services
@using GFI_Upgrated.UI.State
@using System.Text
@inject StoreApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AppSessionState SessionState
@inject IJSRuntime JS

<PageTitle>Item Stock By Batch</PageTitle>

<MudPaper Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4 no-print">
        <MudText Typo="Typo.h5">Item Stock By Batch</MudText>
        <MudMenu Label="Export" StartIcon="@Icons.Material.Filled.SaveAlt" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary" Variant="Variant.Filled">
            <MudMenuItem OnClick="ExportToCopyAsync" Icon="@Icons.Material.Filled.ContentCopy">Copy to Clipboard</MudMenuItem>
            <MudMenuItem OnClick="ExportToCsvAsync" Icon="@Icons.Material.Filled.InsertDriveFile">Export to CSV</MudMenuItem>
            <MudMenuItem OnClick="ExportToPrintAsync" Icon="@Icons.Material.Filled.Print">Print Report</MudMenuItem>
            <MudMenuItem OnClick="ExportToPdfAsync" Icon="@Icons.Material.Filled.PictureAsPdf">Save as PDF</MudMenuItem>
        </MudMenu>
    </MudStack>

    <MudGrid Class="mb-4 no-print" Spacing="2">
        <MudItem xs="12" md="4">
            <MudSelect T="long?" @bind-Value="_selectedStockById" Label="Stock From" Variant="Variant.Outlined" Clearable="true" AnchorOrigin="Origin.BottomCenter">
                <MudSelectItem Value="@((long?)null)">All Sources</MudSelectItem>
                <MudSelectItem Value="@((long?)1)">Purchase</MudSelectItem>
                <MudSelectItem Value="@((long?)2)">Pre-Processing</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudAutocomplete T="RawMaterialDto" Label="Select Item" @bind-Value="_selectedItem" SearchFunc="@SearchItems"
                             ToStringFunc="@(i => i?.ItemName ?? "")" Variant="Variant.Outlined" Clearable="true" 
                             Placeholder="Search items..." AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnSearch" FullWidth="true" Class="py-3">
                Search
            </MudButton>
        </MudItem>
    </MudGrid>

    <div class="print-only mb-6">
        <div style="text-align: center; border-bottom: 2px solid #333; padding-bottom: 12px; margin-bottom: 16px;">
            <h2 style="margin: 0; font-size: 24px; font-weight: bold; color: #111;">GFI</h2>
            <h3 style="margin: 4px 0 0; font-size: 18px; color: #555;">Item Stock By Batch</h3>
            <p style="margin: 4px 0 0; font-size: 12px; color: #777;">Generated on: @DateTime.Now.ToString("g")</p>
        </div>
        <div style="font-size: 14px; margin-bottom: 16px;">
            <strong>Filters Applied:</strong><br />
            Stock From: @(_selectedStockById == 1 ? "Purchase" : _selectedStockById == 2 ? "Pre-Processing" : "All Sources") | 
            Item: @(_selectedItem?.ItemName ?? "All Items")
        </div>
    </div>

    <MudTable T="ItemStockByBatchReportDto" @ref="_table" ServerData="LoadServerDataAsync" Hover="true" Dense="true" Striped="true" Bordered="true" Loading="_loading">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortLabel="ItemStockByBatchId" T="ItemStockByBatchReportDto">ID</MudTableSortLabel></MudTh>
            <MudTh>Item Name</MudTh>
            <MudTh Style="text-align: right;">Quantity</MudTh>
            <MudTh>Batch No.</MudTh>
            <MudTh>Warehouse</MudTh>
            <MudTh Style="text-align: right;">Final Quantity</MudTh>
            <MudTh>Expiry Date</MudTh>
            <MudTh>Stock From</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.ItemStockByBatchId</MudTd>
            <MudTd DataLabel="Item Name">@context.ItemName</MudTd>
            <MudTd DataLabel="Quantity" Style="text-align: right;">@context.Quantity.ToString("N2") @context.UnitName</MudTd>
            <MudTd DataLabel="Batch No.">@context.BatchNo</MudTd>
            <MudTd DataLabel="Warehouse">@context.WarehouseName</MudTd>
            <MudTd DataLabel="Final Quantity" Style="text-align: right;">@context.FinalQuantityLeft.ToString("N2")</MudTd>
            <MudTd DataLabel="Expiry Date">@context.ExpiryDate</MudTd>
            <MudTd DataLabel="Stock From">
                <MudChip T="string" Color="@(context.StockById == 1 ? Color.Info : Color.Warning)" Size="Size.Small">
                    @(context.StockById == 1 ? "Purchase" : context.StockById == 2 ? "PreProcessing" : "Unknown")
                </MudChip>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager Class="no-print" />
        </PagerContent>
        <NoRecordsContent>
            <MudText Class="pa-4">No batch stock records found.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<ItemStockByBatchReportDto>? _table;
    private long? _selectedStockById;
    private RawMaterialDto? _selectedItem;
    private bool _loading;
    private string _currentSortLabel = "ItemStockByBatchId";
    private string _currentSortDirection = "ASC";
    private List<RawMaterialDto> _items = new();

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            var itemResult = await ApiClient.GetItemsForBomLookupAsync(null);
            _items = itemResult.OrderBy(x => x.ItemName).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading items lookup: {ex.Message}", Severity.Error);
        }
    }

    private async Task<IEnumerable<RawMaterialDto>> SearchItems(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return _items;
        return _items.Where(x => x.ItemName?.Contains(value, StringComparison.OrdinalIgnoreCase) == true);
    }

    private async Task<TableData<ItemStockByBatchReportDto>> LoadServerDataAsync(TableState state, CancellationToken cancellationToken)
    {
        _loading = true;
        try
        {
            _currentSortLabel = state.SortLabel ?? "ItemStockByBatchId";
            _currentSortDirection = state.SortDirection == SortDirection.Descending ? "DESC" : "ASC";

            var result = await ApiClient.GetItemStockByBatchReportAsync(
                itemStockByBatchId: null,
                stockById: _selectedStockById,
                itemId: _selectedItem?.ItemId,
                page: state.Page + 1,
                size: state.PageSize,
                sortCol: _currentSortLabel,
                sortOrd: _currentSortDirection,
                cancellationToken: cancellationToken
            );

            if (result.CurrentPage != state.Page + 1 && _table != null)
            {
                _table.NavigateTo(result.CurrentPage - 1);
            }

            return new TableData<ItemStockByBatchReportDto>
            {
                TotalItems = result.TotalRecord,
                Items = result.Items
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading item stock by batch: {ex.Message}", Severity.Error);
            return new TableData<ItemStockByBatchReportDto> { Items = Array.Empty<ItemStockByBatchReportDto>(), TotalItems = 0 };
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch()
    {
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task<List<ItemStockByBatchReportDto>> GetAllDataAsync()
    {
        try
        {
            var result = await ApiClient.GetItemStockByBatchReportAsync(
                itemStockByBatchId: null,
                stockById: _selectedStockById,
                itemId: _selectedItem?.ItemId,
                page: 1,
                size: 1000000,
                sortCol: _currentSortLabel,
                sortOrd: _currentSortDirection
            );
            return result.Items.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading export data: {ex.Message}", Severity.Error);
            return new();
        }
    }

    private async Task ExportToCopyAsync()
    {
        var data = await GetAllDataAsync();
        var sb = new StringBuilder();
        sb.AppendLine("ID\tItem Name\tQuantity\tUnit\tBatch No.\tWarehouse\tFinal Quantity\tExpiry Date\tStock From");
        foreach (var item in data)
        {
            var sourceName = item.StockById == 1 ? "Purchase" : item.StockById == 2 ? "PreProcessing" : "Unknown";
            sb.AppendLine($"{item.ItemStockByBatchId}\t{item.ItemName}\t{item.Quantity}\t{item.UnitName}\t{item.BatchNo}\t{item.WarehouseName}\t{item.FinalQuantityLeft}\t{item.ExpiryDate}\t{sourceName}");
        }
        var success = await JS.InvokeAsync<bool>("gfiCopyToClipboard", sb.ToString());
        if (success)
        {
            Snackbar.Add("Report data copied to clipboard.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to copy data to clipboard.", Severity.Error);
        }
    }
    private async Task ExportToCsvAsync()
    {
        var data = await GetAllDataAsync();
        var sb = new StringBuilder();
        sb.AppendLine("ID,Item Name,Quantity,Unit,Batch No.,Warehouse,Final Quantity,Expiry Date,Stock From");
        foreach (var item in data)
        {
            var sourceName = item.StockById == 1 ? "Purchase" : item.StockById == 2 ? "PreProcessing" : "Unknown";
            var itemName = (item.ItemName ?? "").Replace("\"", "\"\"");
            var unitName = (item.UnitName ?? "").Replace("\"", "\"\"");
            var batchNo = (item.BatchNo ?? "").Replace("\"", "\"\"");
            var whName = (item.WarehouseName ?? "").Replace("\"", "\"\"");
            var expDate = (item.ExpiryDate ?? "").Replace("\"", "\"\"");
            sb.AppendLine($"{item.ItemStockByBatchId},\"{itemName}\",{item.Quantity},\"{unitName}\",\"{batchNo}\",\"{whName}\",{item.FinalQuantityLeft},\"{expDate}\",\"{sourceName}\"");
        }
        await JS.InvokeVoidAsync("gfiDownloadTextFile", $"item-stock-by-batch-{DateTime.Now:yyyyMMddHHmmss}.csv", sb.ToString(), "text/csv;charset=utf-8");
        Snackbar.Add("Report data exported as CSV.", Severity.Success);
    }
    private async Task ExportToPrintAsync()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task ExportToPdfAsync()
    {
        Snackbar.Add("Tip: Choose 'Save as PDF' as the destination in the print window.", Severity.Info);
        await JS.InvokeVoidAsync("window.print");
    }
}
