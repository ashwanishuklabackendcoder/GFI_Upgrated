@page "/admin/units"
@using GFI_Upgrated.SharedDto.Store
@using GFI_Upgrated.UI.Services
@using GFI_Upgrated.UI.State
@inject StoreApiClient ApiClient
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AppSessionState SessionState

<PageTitle>Units</PageTitle>

<MudPaper Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Units</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage measurement units and conversion factors.</MudText>
        </MudStack>
        @if (_canInsert)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OnAdd">
                Add New
            </MudButton>
        }
    </MudStack>

    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2" Class="mb-4">
        <MudTextField @bind-Value="_search" Label="Search units" Variant="Variant.Outlined" Immediate="true" Clearable="true" OnClearButtonClick="SearchAsync" Class="flex-grow-1" />
        <MudButton Variant="Variant.Outlined" OnClick="SearchAsync">Search</MudButton>
    </MudStack>

    <MudTable RowsPerPage="25" T="UnitDto" @ref="_table" ServerData="LoadServerDataAsync" Hover="true" Dense="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="UnitDto" SortLabel="UnitName">Unit Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="UnitDto" SortLabel="ConversionValue">Conversion</MudTableSortLabel></MudTh>
            <MudTh>Base Unit</MudTh>
            <MudTh Style="text-align: center;"><MudTableSortLabel T="UnitDto" SortLabel="IsActive">Status</MudTableSortLabel></MudTh>
            <MudTh Style="width: 120px; text-align: center;">Action</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Unit Name">@context.UnitName</MudTd>
            <MudTd DataLabel="Conversion">@(context.ConversionValue?.ToString() ?? "-")</MudTd>
            <MudTd DataLabel="Base Unit">@(context.BaseName ?? "-")</MudTd>
            <MudTd DataLabel="Status" Style="text-align: center;">
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Text">
                    @(context.IsActive ? "Active" : "Inactive")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Action" Style="text-align: center;">
                <MudStack Row="true" Spacing="1" Justify="Justify.Center" AlignItems="AlignItems.Center">
                    @if (_canUpdate)
                    {
                        <MudTooltip Text="Edit">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OnEdit(context))" />
                        </MudTooltip>
                    }
                    @if (_canDelete)
                    {
                        <MudTooltip Text="Delete">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnDelete(context))" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudText Class="pa-4">No unit records found.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<UnitDto>? _table;
    private string? _search;
    private bool _canInsert;
    private bool _canUpdate;
    private bool _canDelete;

    protected override void OnInitialized()
    {
        if (!SessionState.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var permissions = SessionState.GetPermissions("/admin/units");
        _canInsert = permissions.IsInsert;
        _canUpdate = permissions.IsUpdate;
        _canDelete = permissions.IsDelete;
    }

    private async Task<TableData<UnitDto>> LoadServerDataAsync(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            var result = await ApiClient.GetUnitsAsync(new PagedRequest
            {
                CurrentPage = state.Page + 1,
                RecordPerPage = state.PageSize,
                SortColumn = state.SortLabel ?? "UnitId",
                SortType = state.SortDirection == SortDirection.Ascending ? "ASC" : "DESC"
            }, _search, cancellationToken);

            return new TableData<UnitDto>
            {
                TotalItems = result.TotalRecord,
                Items = result.Items
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            return new TableData<UnitDto> { TotalItems = 0, Items = Array.Empty<UnitDto>() };
        }
    }

    private async Task SearchAsync()
    {
        if (_table is not null) await _table.ReloadServerData();
    }

    private void OnAdd() => Navigation.NavigateTo("/admin/units/new");

    private void OnEdit(UnitDto unit) => Navigation.NavigateTo($"/admin/units/edit/{unit.UnitId}");

    private async Task OnDelete(UnitDto unit)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete unit: {unit.UnitName}?");
        if (!confirmed) return;

        try
        {
            var result = await ApiClient.DeleteUnitAsync(unit.UnitId, SessionState.CurrentUser?.LoginName ?? "System");
            if (result > 0)
            {
                Snackbar.Add("Unit deleted successfully.", Severity.Success);
                if (_table is not null) await _table.ReloadServerData();
            }
            else
            {
                var message = result == -1 ? "Cannot delete unit because it is currently linked to SKUs or BOMs." : "Failed to delete unit.";
                Snackbar.Add(message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("REFERENCE constraint", StringComparison.OrdinalIgnoreCase))
            {
                Snackbar.Add("Cannot delete this unit because it is currently in use in other records.", Severity.Error);
            }
            else
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
