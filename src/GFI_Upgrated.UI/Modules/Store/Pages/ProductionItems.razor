@page "/store/production/items/{HeaderId:long}"
@page "/admin/production/items/{HeaderId:long}"
@using GFI_Upgrated.SharedDto.Store
@using GFI_Upgrated.UI.Services
@using GFI_Upgrated.UI.State
@using GFI_Upgrated.UI.Modules.Store.Components
@inject StoreApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AppSessionState SessionState
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Manage Materials</PageTitle>

<MudPaper Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Material Consumption</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Record raw materials used for Production Run #@HeaderId</MudText>
        </MudStack>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="OnBack">
            Back to List
        </MudButton>
    </MudStack>

    @if (_header != null)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            <b>Produced:</b> @_header.BomName | <b>BOM Batches:</b> @_header.BomQty | <b>Batch No:</b> @_header.BatchNo | <b>Warehouse:</b> @_header.WarehouseName
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Required Materials (BOM)</MudText>
                <MudList T="string">
                    @foreach (var req in _bomItems)
                    {
                        var consumed = _items.Where(i => i.ItemID == req.ItemID).Sum(i => i.Quantity);
                        var remaining = (req.Quantity * (_header?.BomQty ?? 1)) - consumed;
                        <MudListItem Icon="@(remaining <= 0 ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Pending)" IconColor="@(remaining <= 0 ? Color.Success : Color.Warning)">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body1">@req.ItemName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Required: @(req.Quantity * (_header?.BomQty ?? 1)) | Consumed: @consumed | Remaining: @(remaining < 0 ? 0 : remaining)
                                </MudText>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Outlined="true" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.h6">Consumption Records</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog" Disabled="_finalizing">
                        Add Consumption
                    </MudButton>
                </MudStack>

                <MudTable Items="_items" Hover="true" Dense="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Item</MudTh>
                        <MudTh>Batch</MudTh>
                        <MudTh>Quantity</MudTh>
                        <MudTh Style="width: 80px;">Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Item">@context.ItemName</MudTd>
                        <MudTd DataLabel="Batch">@context.BatchNo</MudTd>
                        <MudTd DataLabel="Quantity">@context.Quantity</MudTd>
                        <MudTd DataLabel="Action">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnDeleteItem(context))" Disabled="_finalizing" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OnFinalize" Disabled="@(_items.Count == 0 || _finalizing)">
                        @(_finalizing ? "Finalizing..." : "Finalize & Update Stock")
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter] public long HeaderId { get; set; }
    private ProductionDto? _header;
    private List<PreProcessingItemDto> _items = new();
    private List<BomItemDetailDto> _bomItems = new();
    private bool _finalizing;

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _header = await ApiClient.GetProductionByIdAsync(HeaderId);
            if (_header == null) { Snackbar.Add("Header not found.", Severity.Error); OnBack(); return; }

            _bomItems = (await ApiClient.GetBomItemsAsync(_header.BomId)).ToList();
            _items = (await ApiClient.GetProductionItemsAsync(HeaderId)).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void OnBack() => Navigation.NavigateTo("/store/production");

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            { nameof(ProductionItemDialog.HeaderId), HeaderId },
            { nameof(ProductionItemDialog.BomItems), _bomItems }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ProductionItemDialog>("Add Consumption", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadDataAsync();
        }
    }

    private async Task OnDeleteItem(PreProcessingItemDto item)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this material record for '{item.ItemName}' (Qty: {item.Quantity})?");
        if (!confirmed) return;

        try
        {
            var result = await ApiClient.DeleteProductionItemAsync(item.ItemStockUsedID);
            if (result > 0)
            {
                Snackbar.Add("Material record deleted successfully.", Severity.Success);
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add("Failed to delete material record.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnFinalize()
    {
        _finalizing = true;
        try
        {
            var result = await ApiClient.FinalizeProductionStockAsync(HeaderId, SessionState.CurrentUser?.LoginName ?? "System");
            if (result > 0)
            {
                Snackbar.Add("Stock updated successfully.", Severity.Success);
                Navigation.NavigateTo("/store/production");
            }
            else
            {
                Snackbar.Add("Failed to finalize stock.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _finalizing = false;
        }
    }
}
