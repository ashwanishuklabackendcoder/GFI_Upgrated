@page "/store/w_masterbrandsaddlist"
@page "/store/brands"
@page "/admin/w_masterbrandsaddlist"
@page "/admin/brands"
@using GFI_Upgrated.SharedDto.Store
@inject AppSessionState SessionState
@inject LocalizationState LocalizationState
@inject NavigationManager Navigation
@inject StoreApiClient ApiClient
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>@LocalizationState.Text("Store.Brands.List.PageTitle", "Brands")</PageTitle>

<MudPaper Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@LocalizationState.Text("Store.Brands.List.Title", "Brands")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@LocalizationState.Text("Store.Brands.List.Subtitle", "Manage product brands and their details.")</MudText>
        </MudStack>
        @if (_canInsert)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NewBrand">
                @LocalizationState.Text("Common.Actions.AddNew", "Add New")
            </MudButton>
        }
    </MudStack>

    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2" Class="mb-4">
        <MudTextField @bind-Value="_search" Label="@LocalizationState.Text("Store.Brands.List.SearchLabel", "Search brands")" Variant="Variant.Outlined" Immediate="true" Clearable="true" OnClearButtonClick="SearchAsync" Class="flex-grow-1" />
        <MudButton Variant="Variant.Outlined" OnClick="SearchAsync">@LocalizationState.Text("Common.Actions.Search", "Search")</MudButton>
    </MudStack>

    <MudTable RowsPerPage="25" T="GFI_Upgrated.SharedDto.Store.BrandDto" @ref="_table" ServerData="LoadServerDataAsync" Hover="true" Dense="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="GFI_Upgrated.SharedDto.Store.BrandDto" SortLabel="BrandName">@LocalizationState.Text("Store.Brands.List.BrandName", "Brand Name")</MudTableSortLabel></MudTh>
            <MudTh Style="text-align: center;"><MudTableSortLabel T="GFI_Upgrated.SharedDto.Store.BrandDto" SortLabel="IsActive">@LocalizationState.Text("Store.Brands.List.Status", "Status")</MudTableSortLabel></MudTh>
            <MudTh>@LocalizationState.Text("Store.Brands.List.Remarks", "Remarks")</MudTh>
            <MudTh Style="width: 120px; text-align: center;">@LocalizationState.Text("Store.Brands.List.Action", "Action")</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@LocalizationState.Text("Store.Brands.List.BrandName", "Brand Name")">@context.BrandName</MudTd>
            <MudTd DataLabel="@LocalizationState.Text("Store.Brands.List.Status", "Status")" Style="text-align: center;">
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Text">
                    @(context.IsActive ? LocalizationState.Text("Common.Status.Active", "Active") : LocalizationState.Text("Common.Status.Inactive", "Inactive"))
                </MudChip>
            </MudTd>
            <MudTd DataLabel="@LocalizationState.Text("Store.Brands.List.Remarks", "Remarks")">@context.Remarks</MudTd>
            <MudTd DataLabel="@LocalizationState.Text("Store.Brands.List.Action", "Action")" Style="text-align: center;">
                <MudStack Row="true" Spacing="1" Justify="Justify.Center" AlignItems="AlignItems.Center">
                    @if (_canUpdate)
                    {
                        <MudTooltip Text="@LocalizationState.Text("Common.Actions.Edit", "Edit")">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OnEdit(context))" />
                        </MudTooltip>
                    }
                    @if (_canDelete)
                    {
                        <MudTooltip Text="@LocalizationState.Text("Common.Actions.Delete", "Delete")">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnDelete(context))" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudText Class="pa-4">@LocalizationState.Text("Store.Brands.List.NoRecords", "No brand records found.")</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<GFI_Upgrated.SharedDto.Store.BrandDto>? _table;
    private string? _search;
    
    private bool _canInsert;
    private bool _canUpdate;
    private bool _canDelete;

    protected override void OnInitialized()
    {
        if (!SessionState.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?')[0];
        _canInsert = SessionState.HasPermission(path, "insert");
        _canUpdate = SessionState.HasPermission(path, "update");
        _canDelete = SessionState.HasPermission(path, "delete");
    }

    private async Task<TableData<GFI_Upgrated.SharedDto.Store.BrandDto>> LoadServerDataAsync(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            var result = await ApiClient.GetBrandsAsync(new PagedRequest
            {
                CurrentPage = state.Page + 1,
                RecordPerPage = state.PageSize,
                SortColumn = string.IsNullOrWhiteSpace(state.SortLabel) ? "BrandId" : state.SortLabel,
                SortType = state.SortDirection == SortDirection.Ascending ? "ASC" : "DESC"
            }, _search, cancellationToken);
    
            return new TableData<GFI_Upgrated.SharedDto.Store.BrandDto>
            {
                TotalItems = result.TotalRecord,
                Items = result.Items
            };
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", $"LoadServerDataAsync Error: {ex.Message}");
            Snackbar.Add(LocalizationState.Text("Store.Brands.List.LoadError", "Unable to load brand records."), Severity.Error);
            return new TableData<GFI_Upgrated.SharedDto.Store.BrandDto>
            {
                TotalItems = 0,
                Items = Array.Empty<GFI_Upgrated.SharedDto.Store.BrandDto>()
            };
        }
    }

    private async Task SearchAsync()
    {
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }

    private void NewBrand()
    {
        Navigation.NavigateTo("/store/w_masterbrandsaddlist/new");
    }

    private void OnEdit(GFI_Upgrated.SharedDto.Store.BrandDto brand)
    {
        Navigation.NavigateTo($"/store/w_masterbrandsaddlist/edit/{brand.BrandId}");
    }

    private async Task OnDelete(GFI_Upgrated.SharedDto.Store.BrandDto brand)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", LocalizationState.Format("Store.Brands.List.DeleteConfirm", "Are you sure you want to delete brand: {0}?", brand.BrandName));
        if (!confirmed) return;

        try
        {
            var result = await ApiClient.DeleteBrandAsync(brand.BrandId, SessionState.CurrentUser?.LoginName ?? "System");
            if (result > 0)
            {
                Snackbar.Add(LocalizationState.Text("Store.Brands.List.DeleteSuccess", "Brand deleted successfully."), Severity.Success);
                if (_table is not null) await _table.ReloadServerData();
            }
            else
            {
                Snackbar.Add(LocalizationState.Text("Store.Brands.List.DeleteFailed", "Failed to delete brand."), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
