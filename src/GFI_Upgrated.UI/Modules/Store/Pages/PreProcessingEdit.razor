@page "/store/preprocessing/new"
@page "/store/preprocessing/edit/{Id:long}"
@page "/admin/preprocessing/new"
@page "/admin/preprocessing/edit/{Id:long}"
@using GFI_Upgrated.SharedDto.Store
@using GFI_Upgrated.UI.Services
@using GFI_Upgrated.UI.State
@inject StoreApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject AppSessionState SessionState

<PageTitle>@(_isEdit ? "Edit Pre-Processing" : "New Pre-Processing")</PageTitle>

<MudPaper Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@(_isEdit ? "Edit Production Run" : "New Production Run")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Declare what was produced and where it is stored.</MudText>
        </MudStack>
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="OnCancel" />
    </MudStack>

    <EditForm Model="_editor" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="long" @bind-Value="_editor.BomId" Label="Select BOM" Variant="Variant.Outlined" For="@(() => _editor.BomId)" AnchorOrigin="Origin.BottomCenter" Required="true">
                    <MudSelectItem Value="0L">-- Select BOM --</MudSelectItem>
                    @foreach (var bom in _boms)
                    {
                        <MudSelectItem Value="@bom.BomId">@bom.BomName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField @bind-Value="_editor.BomQty" Label="BOM Quantity" Variant="Variant.Outlined" For="@(() => _editor.BomQty)" Min="1" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudDatePicker @bind-Date="_editor.ProcessingDate" Label="Processing Date" Variant="Variant.Outlined" For="@(() => _editor.ProcessingDate)" Required="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="_editor.QuantityMade" Label="Actual Quantity Made" Min="1" Variant="Variant.Outlined" For="@(() => _editor.QuantityMade)" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="long" @bind-Value="_editor.UnitMade" Label="Unit" Variant="Variant.Outlined" For="@(() => _editor.UnitMade)" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="0L">-- Select Unit --</MudSelectItem>
                    @foreach (var unit in _units)
                    {
                        <MudSelectItem Value="@unit.UnitId">@unit.UnitName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_editor.BatchNumberMade" Label="Batch Number" Variant="Variant.Outlined" HelperText="Leave blank for auto-generation" For="@(() => _editor.BatchNumberMade)" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudDatePicker @bind-Date="_editor.ExpiryDate" Label="Expiry Date" Variant="Variant.Outlined" For="@(() => _editor.ExpiryDate)" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="long" @bind-Value="_editor.WarehouseId" Label="Storage Warehouse" Variant="Variant.Outlined" For="@(() => _editor.WarehouseId)" AnchorOrigin="Origin.BottomCenter" Required="true">
                    <MudSelectItem Value="0L">-- Select Warehouse --</MudSelectItem>
                    @foreach (var wh in _warehouses)
                    {
                        <MudSelectItem Value="@wh.WarehouseId">@wh.WarehouseName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_editor.ProcessEmployees" Label="Process Employees (CSV)" Variant="Variant.Outlined" For="@(() => _editor.ProcessEmployees)" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_editor.Remarks" Label="Remarks" Variant="Variant.Outlined" Lines="2" For="@(() => _editor.Remarks)" />
            </MudItem>

            <MudItem xs="12" Class="pt-4">
                <MudStack Row="true" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled" Disabled="_processing">
                        @(_processing ? "Saving..." : (_isEdit ? "Update Header" : "Create Header & Add Stock"))
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="OnCancel" Disabled="_processing">Cancel</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudPaper>

@code {
    [Parameter] public long? Id { get; set; }
    private bool _isEdit => Id.HasValue && Id.Value > 0;
    private SavePreProcessingRequest _editor = new() { ProcessingDate = DateTime.Today, ExpiryDate = DateTime.Today.AddYears(1) };
    private List<BomLookupDto> _boms = new();
    private List<WarehouseLookupDto> _warehouses = new();
    private List<UnitLookupDto> _units = new();
    private bool _processing;

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsLoggedIn)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadLookupsAsync();

        if (_isEdit)
        {
            var selected = await ApiClient.GetPreProcessingByIdAsync(Id!.Value);
            if (selected is not null)
            {
                _editor.PreProcessingId = selected.PreProcessingId;
                _editor.BomId = selected.BomId;
                _editor.BomQty = selected.BomQty;
                _editor.ProcessingDate = DateTime.TryParse(selected.ProcessingDate, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var pd) ? pd : DateTime.Today;
                _editor.QuantityMade = selected.QuantityMade;
                _editor.UnitMade = selected.UnitMade;
                _editor.BatchNumberMade = selected.BatchNumberMade;
                _editor.ExpiryDate = DateTime.TryParse(selected.ExpiryDate, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var ed) ? ed : DateTime.Today.AddYears(1);
                _editor.ProcessEmployees = selected.ProcessEmployees;
                _editor.Remarks = selected.Remarks;
                _editor.DocumentUpload = selected.DocumentUpload;
                _editor.WarehouseId = selected.WarehouseId;
            }
        }
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            var bomsTask = ApiClient.GetBomsLookupAsync();
            var whTask = ApiClient.GetWarehousesLookupAsync();
            var unitsTask = ApiClient.GetUnitsLookupAsync();

            await Task.WhenAll(bomsTask, whTask, unitsTask);

            _boms = (await bomsTask).ToList();
            _warehouses = (await whTask).ToList();
            _units = (await unitsTask).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading lookups: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        if (_editor.BomId == 0) { Snackbar.Add("Please select a BOM.", Severity.Warning); return; }
        if (_editor.WarehouseId == 0) { Snackbar.Add("Please select a Warehouse.", Severity.Warning); return; }

        if (_editor.ExpiryDate.HasValue && _editor.ExpiryDate.Value.Date < DateTime.Today)
        {
            Snackbar.Add("Expiry date cannot be in the past.", Severity.Warning);
            return;
        }

        _processing = true;
        try
        {
            _editor.UpdatedBy = SessionState.CurrentUser?.LoginName ?? "System";
            var result = await ApiClient.SavePreProcessingAsync(_editor);
            if (result > 0)
            {
                Snackbar.Add("Pre-Processing header saved successfully.", Severity.Success);
                if (!_isEdit)
                {
                    // Navigate to Items management if new
                    NavigationManager.NavigateTo($"/store/preprocessing/items/{result}");
                }
                else
                {
                    NavigationManager.NavigateTo("/store/preprocessing");
                }
            }
            else
            {
                Snackbar.Add("Failed to save record.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private void OnCancel() => NavigationManager.NavigateTo("/store/preprocessing");
}
