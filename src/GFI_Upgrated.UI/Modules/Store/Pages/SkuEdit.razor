@page "/store/w_masterskuaddlist/new"
@page "/store/w_masterskuaddlist/edit/{Id:long}"
@using GFI_Upgrated.SharedDto.Store
@using GFI_Upgrated.UI.Services
@using GFI_Upgrated.UI.State
@inject StoreApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject AppSessionState SessionState

<MudPaper Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@(_isEdit ? "Edit SKU" : "Add New SKU")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Enter SKU details below.</MudText>
        </MudStack>
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="OnCancel" />
    </MudStack>

        <EditForm Model="_editor" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_editor.SkuName" Label="SKU Name" Variant="Variant.Outlined" For="@(() => _editor.SkuName)" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="long" @bind-Value="_editor.UnitId" Label="Unit" Variant="Variant.Outlined" For="@(() => _editor.UnitId)" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem Value="0L">Select Unit</MudSelectItem>
                        @foreach (var unit in _units)
                        {
                            <MudSelectItem Value="@unit.UnitId">@unit.UnitName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField @bind-Value="_editor.Quantity" Label="Quantity" Variant="Variant.Outlined" For="@(() => _editor.Quantity)" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField @bind-Value="_editor.QuantityPerColli" Label="Qty Per Colli" Variant="Variant.Outlined" For="@(() => _editor.QuantityPerColli)" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_editor.Remarks" Label="Remarks" Variant="Variant.Outlined" Lines="3" For="@(() => _editor.Remarks)" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Value="_editor.IsActive" Label="Is Active" Color="Color.Primary" />
                </MudItem>

            <MudItem xs="12" Class="pt-4">
                <MudStack Row="true" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled" Disabled="_processing">@(_processing ? "Saving..." : "Save SKU")</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="OnCancel" Disabled="_processing">Cancel</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudPaper>

@code {
    [Parameter] public long? Id { get; set; }
    private bool _isEdit => Id.HasValue && Id.Value > 0;
    private SaveSkuRequest _editor = new();
    private List<UnitLookupDto> _units = new();
    private bool _processing;

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsLoggedIn)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadUnitsAsync();
        
        if (_isEdit)
        {
            var selected = await ApiClient.GetSkuByIdAsync(Id!.Value);
            if (selected is not null)
            {
                _editor.SkuId = selected.SkuId;
                _editor.SkuName = selected.SkuName;
                _editor.UnitId = selected.UnitId;
                _editor.Quantity = selected.Quantity;
                _editor.QuantityPerColli = selected.QuantityPerColli;
                _editor.Remarks = selected.Remarks;
                _editor.IsActive = selected.IsActive;
            }
        }
    }

    private async Task LoadUnitsAsync()
    {
        try
        {
            var result = await ApiClient.GetUnitsLookupAsync();
            _units = result.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading units: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        _processing = true;
        try
        {
            _editor.UpdatedBy = SessionState.CurrentUser?.LoginName ?? "System";
            var result = await ApiClient.SaveSkuAsync(_editor);
            if (result > 0)
            {
                Snackbar.Add("SKU saved successfully.", Severity.Success);
                NavigationManager.NavigateTo("/store/w_masterskuaddlist");
            }
            else
            {
                Snackbar.Add("Failed to save SKU.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private void OnCancel() => NavigationManager.NavigateTo("/store/w_masterskuaddlist");
}
