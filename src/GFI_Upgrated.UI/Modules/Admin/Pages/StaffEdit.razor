@page "/admin/staff/new"
@page "/admin/staff/edit/{StaffId:long}"
@inject AppSessionState SessionState
@inject LocalizationState LocalizationState
@inject NavigationManager Navigation
@inject AdminSecurityApiClient ApiClient

<PageTitle>@_title</PageTitle>

<MudPaper Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@_title</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@LocalizationState.Text("Admin.Staff.Edit.Subtitle", "Add or edit staff details using the legacy field set.")</MudText>
        </MudStack>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="Cancel">@LocalizationState.Text("Common.Actions.BackToList", "Back to List")</MudButton>
    </MudStack>

    <EditForm Model="_editor" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSelect T="string" Label="@LocalizationState.Text("Admin.Staff.Edit.Salutation", "Salutation")" Variant="Variant.Outlined" @bind-Value="_editor.StaffSalutation">
                    <MudSelectItem T="string" Value="@string.Empty">@LocalizationState.Text("Admin.Staff.Edit.SelectItem", "Select Item")</MudSelectItem>
                    @foreach (var item in _salutations)
                    {
                        <MudSelectItem T="string" Value="@item.Value.ToString()">@item.Text</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_editor.StaffFirstName" Label="@LocalizationState.Text("Admin.Staff.Edit.FirstName", "First Name")" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_editor.StaffLastName" Label="@LocalizationState.Text("Admin.Staff.Edit.LastName", "Last Name")" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_editor.StaffNumber" Label="@LocalizationState.Text("Admin.Staff.Edit.StaffNumber", "Staff Number")" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_editor.NIN" Label="@LocalizationState.Text("Admin.Staff.Edit.NIN", "NIN")" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudDatePicker @bind-Date="_editor.DOB" Label="@LocalizationState.Text("Admin.Staff.Edit.Dob", "D.O.B")" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_editor.MobileNo" Label="@LocalizationState.Text("Admin.Staff.Edit.MobileNo", "Mobile No.")" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_editor.EmailIDPersonal" Label="@LocalizationState.Text("Admin.Staff.Edit.EmailPersonal", "Email Personal")" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_editor.EmailIDOfficial" Label="@LocalizationState.Text("Admin.Staff.Edit.EmailOfficial", "Email Official")" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudSelect T="long" Label="@LocalizationState.Text("Admin.Staff.Edit.Gender", "Gender")" Variant="Variant.Outlined" @bind-Value="_editor.Gender">
                    <MudSelectItem T="long" Value="@((long)0)">@LocalizationState.Text("Admin.Staff.Edit.Select", "Select")</MudSelectItem>
                    @foreach (var item in _genders)
                    {
                        <MudSelectItem T="long" Value="@item.Value">@item.Text</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <label class="form-label">@LocalizationState.Text("Admin.Staff.Edit.Photo", "Photo")</label>
                <InputFile OnChange="OnPhotoChanged" class="form-control" />
                @if (!string.IsNullOrWhiteSpace(_selectedPhotoName))
                {
                    <MudText Typo="Typo.caption" Class="mt-1">@_selectedPhotoName</MudText>
                }
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField T="int" @bind-Value="_editor.Status" Label="@LocalizationState.Text("Admin.Staff.Edit.Status", "Status")" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" Class="pt-2">
                <MudCheckBox T="bool" @bind-Value="_editor.HasLogin" Label="@LocalizationState.Text("Admin.Staff.Edit.HasLogin", "Has Login")" />
            </MudItem>

            <MudItem xs="12" Class="pt-2">
                <MudStack Row="true" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled" Disabled="_busy">@LocalizationState.Text("Common.Actions.Submit", "Submit")</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="Cancel" Disabled="_busy">@LocalizationState.Text("Common.Actions.Cancel", "Cancel")</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">@_message</MudAlert>
    }
</MudPaper>

@code {
    [Parameter]
    public long StaffId { get; set; }

    private readonly SaveStaffRequest _editor = new()
    {
        Status = 1
    };
    private IReadOnlyList<LookupItemDto> _salutations = Array.Empty<LookupItemDto>();
    private IReadOnlyList<LookupItemDto> _genders = Array.Empty<LookupItemDto>();
    private bool _busy;
    private string? _message;
    private string? _selectedPhotoName;
    private string _title = string.Empty;

    protected override void OnInitialized()
    {
        if (!SessionState.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _title = LocalizationState.Text("Admin.Staff.Edit.PageTitle.Add", "Add Staff");
        _salutations = await ApiClient.GetMasterDropdownAsync(1);
        _genders = await ApiClient.GetMasterDropdownAsync(2);

        if (StaffId > 0)
        {
            _title = LocalizationState.Text("Admin.Staff.Edit.PageTitle.Edit", "Edit Staff");
            var selected = await ApiClient.GetStaffByIdAsync(StaffId);
            if (selected is not null)
            {
                _editor.StaffId = selected.StaffId;
                _editor.Status = selected.Status;
                _editor.StaffSalutation = selected.StaffSalutation;
                _editor.StaffFirstName = selected.StaffFirstName;
                _editor.StaffLastName = selected.StaffLastName;
                _editor.StaffNumber = selected.StaffNumber;
                _editor.NIN = selected.NIN;
                _editor.DOB = selected.DOB;
                _editor.Gender = selected.Gender;
                _editor.MobileNo = selected.MobileNo;
                _editor.EmailIDPersonal = selected.EmailIDPersonal;
                _editor.EmailIDOfficial = selected.EmailIDOfficial;
                _editor.Photo = selected.Photo;
                _editor.HasLogin = selected.HasLogin;
                _selectedPhotoName = selected.Photo;
            }
        }
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _message = null;
        try
        {
            _editor.CreatedBy = SessionState.CurrentUser?.LoginName ?? "System";
            _editor.UpdatedBy = SessionState.CurrentUser?.LoginName ?? "System";
            if (!string.IsNullOrWhiteSpace(_selectedPhotoName))
            {
                _editor.Photo = _selectedPhotoName;
            }

            var id = await ApiClient.SaveStaffAsync(_editor);
            if (id > 0)
            {
                Navigation.NavigateTo("/admin/staff");
                return;
            }

            _message = LocalizationState.Text("Admin.Staff.Edit.SaveFailed", "Staff save failed.");
        }
        catch (Exception ex)
        {
            _message = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/admin/staff");
    }

    private void OnPhotoChanged(InputFileChangeEventArgs args)
    {
        var file = args.File;
        _selectedPhotoName = file.Name;
        _editor.Photo = file.Name;
    }
}
