@inherits LayoutComponentBase
@implements IDisposable
@inject AppSessionState SessionState
@inject LocalizationState LocalizationState
@inject AdminSecurityApiClient ApiClient
@inject IJSRuntime JSRuntime

<div class="dashboard-shell @(_sidebarCollapsed ? "sidebar-collapsed" : "") @(_sidebarMobileOpen ? "sidebar-mobile-open" : "")">
    @if (_sidebarMobileOpen)
    {
        <div class="sidebar-overlay" @onclick="ToggleMobileSidebar"></div>
    }
    <aside class="dashboard-sidebar">
        <NavMenu />
    </aside>

    <div class="dashboard-content">
        <header class="dashboard-topbar">
            <button type="button" class="icon-chip sidebar-toggle-btn d-lg-none" aria-label="Toggle Menu" @onclick="ToggleMobileSidebar">
                <i class="ti ti-menu-2"></i>
            </button>
            <button type="button" class="icon-chip sidebar-toggle-btn d-none d-lg-inline-flex" aria-label="Collapse Menu" @onclick="ToggleDesktopSidebar">
                <i class="ti ti-menu-2"></i>
            </button>
            <div class="dashboard-topbar-actions" style="margin-left: auto;">
                @if (SessionState.IsLoggedIn && LocalizationState.Languages.Count > 0)
                {
                    <MudSelect T="long"
                               Value="SelectedLanguageId"
                               ValueChanged="OnLanguageChangedAsync"
                               Label="@LocalizationState.Text("Layout.Language", "Language")"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Margin="Margin.Dense"
                               Style="min-width: 180px;">
                        @foreach (var language in LocalizationState.Languages)
                        {
                            <MudSelectItem T="long" Value="@language.Id">@language.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                }

                <button type="button" class="icon-chip" aria-label="@LocalizationState.Text("Layout.Theme", "Theme")" @onclick="ToggleTheme">
                    <i class="@(SessionState.IsDarkMode ? "ti ti-moon" : "ti ti-sun-high")"></i>
                </button>

                <div class="user-chip">
                    <div class="user-chip-avatar">
                        @(GetInitials())
                    </div>
                    <div class="user-chip-text">
                        <span class="user-chip-name">@(SessionState.CurrentUser?.FullName ?? LocalizationState.Text("Common.Guest", "Guest"))</span>
                        <span class="user-chip-role">@(SessionState.CurrentUser?.RoleName ?? LocalizationState.Text("Common.User", "User"))</span>
                    </div>
                </div>

                @if (SessionState.IsLoggedIn)
                {
                    <button type="button" class="icon-chip text-danger" aria-label="@LocalizationState.Text("Layout.Logout", "Logout")" @onclick="Logout" style="margin-left: 8px;">
                        <i class="ti ti-logout"></i>
                    </button>
                }
            </div>
        </header>

        <main role="main" class="dashboard-main" id="divContentPlaceHolder">
            @Body
        </main>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private bool _sidebarCollapsed;
    private bool _sidebarMobileOpen;

    private void ToggleDesktopSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }

    private void ToggleMobileSidebar()
    {
        _sidebarMobileOpen = !_sidebarMobileOpen;
    }

    private long SelectedLanguageId => LocalizationState.CurrentLanguageId > 0
        ? LocalizationState.CurrentLanguageId
        : SessionState.CurrentUser?.LanguageId ?? 0;

    private string GetInitials()
    {
        var name = SessionState.CurrentUser?.FullName;
        if (string.IsNullOrWhiteSpace(name))
        {
            return "GI";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 1)
        {
            return parts[0].Length >= 2 ? parts[0][..2].ToUpperInvariant() : parts[0].ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[1][0]).ToUpperInvariant();
    }

    private async Task ToggleTheme()
    {
        await SessionState.ToggleThemeAsync(JSRuntime);
    }

    private async Task Logout()
    {
        await LocalizationState.ClearAsync(JSRuntime);
        await SessionState.UpdateUserAsync(JSRuntime, null);
        Navigation.NavigateTo("/login");
    }

    private async Task OnLanguageChangedAsync(long languageId)
    {
        await LocalizationState.SetLanguageAsync(SessionState, ApiClient, JSRuntime, languageId);
    }

    private void CheckAccess(string url)
    {
        if (SessionState.CurrentUser == null)
        {
            if (!url.Contains("/login", StringComparison.OrdinalIgnoreCase))
            {
                Navigation.NavigateTo("/login");
            }
            return;
        }

        var uri = new Uri(url);
        var path = uri.AbsolutePath.ToLower();

        if (path == "/" || path.Equals("/admin", StringComparison.OrdinalIgnoreCase) || path.Contains("/login", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        if (!SessionState.HasPermission(path, "view"))
        {
            Navigation.NavigateTo("/access-denied");
        }
    }

    protected override void OnInitialized()
    {
        SessionState.OnChange += StateHasChanged;
        LocalizationState.OnChange += StateHasChanged;
        Navigation.LocationChanged += OnLocationChanged;
        CheckAccess(Navigation.Uri);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _sidebarMobileOpen = false;
        CheckAccess(e.Location);
    }

    public void Dispose()
    {
        SessionState.OnChange -= StateHasChanged;
        LocalizationState.OnChange -= StateHasChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
