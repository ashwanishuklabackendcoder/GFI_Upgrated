@implements IDisposable
<MudThemeProvider IsDarkMode="@SessionState.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@inject UI.State.AppSessionState SessionState
@inject UI.State.LocalizationState LocalizationState
@inject AdminSecurityApiClient ApiClient
@inject IJSRuntime JSRuntime

@if (_initialized)
{
    <Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="main" />
    </Found>
    <NotFound>
        <PageTitle>@LocalizationState.Text("Common.NotFound", "Not found")</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">@LocalizationState.Text("Common.NotFound", "Sorry, there's nothing at this address.")</p>
        </LayoutView>
    </NotFound>
</Router>
}
else
{
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@LocalizationState.Text("Common.Loading", "Loading...")</span>
        </div>
    </div>
}

@code {
    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        SessionState.OnChange += StateHasChanged;
        await SessionState.InitializeAsync(JSRuntime);
        await LocalizationState.InitializeAsync(SessionState, ApiClient, JSRuntime);
        _initialized = true;
    }

    public void Dispose()
    {
        SessionState.OnChange -= StateHasChanged;
    }
}
